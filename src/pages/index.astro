---
import { getCollection, getEntry, render } from 'astro:content';
import AcquisitionCTA from '../components/AcquisitionCTA.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteEntry = await getEntry('site', 'default');
if (!siteEntry) throw new Error('Site config missing');
const siteConfig = siteEntry.data;

const marketStats = (await getCollection('marketStats')).sort(
  (a, b) => a.data.order - b.data.order,
);
const useCases = (await getCollection('useCases')).sort(
  (a, b) => a.data.order - b.data.order,
);
const pillars = (await getCollection('valuePillars')).sort(
  (a, b) => a.data.order - b.data.order,
);

const renderedUseCases = await Promise.all(
  useCases.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);

const formatValuation = (min: number, max: number) =>
  `$${(min / 1000).toFixed(0)}K – $${(max / 1000).toFixed(0)}K`;
---

<BaseLayout>
  <Nav />

  <main>
    <!-- HERO -->
    <header class="hero-bg min-h-[100dvh] flex items-center pt-16 relative">
      <div class="max-w-screen-2xl mx-auto px-8 pt-12 pb-20">
        <div class="max-w-5xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-8">
            <div class="flex items-center gap-x-1.5">
              <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
              <span class="text-emerald-400 text-xs font-semibold tracking-[1.5px] uppercase">Premium .com • Available Now</span>
            </div>
          </div>

          <div class="max-w-4xl">
            <h1 class="font-display text-[4.25rem] md:text-[5.75rem] leading-[0.95] tracking-[-4.5px] font-extrabold mb-2">
              STOP<br />OVERTHINKING.<br />
              <span class="premium-gradient">START DOING.</span>
            </h1>

            <div class="flex items-baseline gap-x-3 mb-6">
              <span class="font-mono text-4xl md:text-5xl text-orange-500 font-semibold tracking-[-2px]">{SITE.name}</span>
            </div>

            <p class="max-w-2xl text-2xl md:text-3xl text-slate-300 font-light tracking-tight leading-tight mb-10">
              The exact-match domain that turns hesitation into momentum.<br />
              Own the phrase millions search when they're ready to change.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <AcquisitionCTA label="Secure This Domain" variant="white" icon="fa-lock" />
            <a href="#why" class="px-8 py-4 border border-white/30 hover:bg-white/5 active:bg-white/10 transition-all font-semibold text-lg rounded-3xl flex items-center justify-center gap-x-2 w-full sm:w-auto text-white no-underline">
              <span>Discover the Value</span>
            </a>
          </div>

          <div class="mt-10 flex items-center gap-x-8 text-sm">
            <div class="flex items-center gap-x-2 text-slate-400">
              <i class="fa-solid fa-check text-emerald-400"></i>
              <span>Instant brand equity</span>
            </div>
            <div class="flex items-center gap-x-2 text-slate-400">
              <i class="fa-solid fa-check text-emerald-400"></i>
              <span>High-intent exact match</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 hidden lg:block">
        <div class="flex flex-col items-center text-xs tracking-[2px] text-slate-500">
          <span>SCROLL TO EXPLORE</span>
          <i class="fa-solid fa-chevron-down mt-1.5 animate-bounce"></i>
        </div>
      </div>
    </header>

    <!-- TRUST BAR -->
    <div class="border-b border-slate-800 bg-slate-900/60 py-5">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-3 text-sm">
          {
            siteConfig.trustPoints.map((point) => (
              <div class="flex items-center gap-x-2 text-slate-400">
                <i class="fa-solid fa-circle-check text-orange-400"></i>
                <span class="font-medium">{point}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- WHY THIS DOMAIN -->
    <section id="why" class="max-w-screen-2xl mx-auto px-8 pt-20 pb-16">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <div class="inline-block px-4 py-1 rounded-3xl bg-orange-500/10 text-orange-400 text-xs font-bold tracking-[2px] mb-4">THE OPPORTUNITY</div>
        <h2 class="section-header tracking-[-2.5px]">This isn't just a domain.<br />It's a movement starter.</h2>
        <p class="mt-5 text-xl text-slate-400">"Stop overthinking and start doing" is the exact phrase people type when analysis paralysis has gone on long enough. Owning the .com gives you direct access to that moment of decision.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {
          pillars.map((pillar, i) => (
            <div class="value-card bg-slate-900 border border-slate-800 rounded-3xl p-8">
              <div class="w-12 h-12 flex items-center justify-center rounded-2xl bg-orange-500/10 text-orange-400 mb-6">
                <span class="text-2xl font-extrabold font-display">{pillar.data.number}</span>
              </div>
              <h3 class="font-semibold text-2xl tracking-tight mb-3">{pillar.data.title}</h3>
              <p class="text-slate-400 leading-relaxed">{pillar.data.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- THE SHIFT VISUAL + COPY -->
    <section class="action-bg py-20 border-y border-slate-800">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="max-w-4xl mx-auto text-center">
          <div class="mx-auto mb-8 inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/5 border border-white/10">
            <i class="fa-solid fa-arrow-right-arrow-left text-5xl text-orange-400"></i>
          </div>

          <h2 class="font-display text-6xl md:text-7xl tracking-[-3.5px] leading-none font-extrabold mb-6">
            From <span class="line-through opacity-60">overthinking</span><br />
            to <span class="text-orange-400">doing</span>.
          </h2>
          <p class="text-2xl text-slate-300 max-w-md mx-auto">This domain doesn't just describe the problem.<br />It owns the solution.</p>
        </div>
      </div>
    </section>

    <!-- BEST USES -->
    <section id="uses" class="max-w-screen-2xl mx-auto px-8 py-20">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-y-4 mb-12">
        <div>
          <div class="text-orange-400 text-xs font-bold tracking-[2.5px] mb-2">ENDLESS POSSIBILITIES</div>
          <h2 class="section-header tracking-[-2px]">Built for the entire<br />self-improvement ecosystem.</h2>
        </div>
        <p class="max-w-md text-lg text-slate-400">Whether you're launching a coaching empire, a habit app, or a movement — this domain becomes your unfair advantage.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          renderedUseCases.map(({ entry, Content }) => {
            const { title, category, icon, gradient } = entry.data;
            return (
              <div class="use-case-card group bg-slate-900 border border-slate-800 hover:border-orange-500/60 rounded-3xl p-8 flex flex-col">
                <div class="flex items-center gap-x-4 mb-6">
                  <div class={`w-11 h-11 rounded-2xl bg-gradient-to-br ${gradient} flex items-center justify-center flex-shrink-0`}>
                    <i class={`fa-solid ${icon} text-white text-2xl`}></i>
                  </div>
                  <div>
                    <div class="font-semibold text-xl tracking-tight">{title}</div>
                    <div class="text-orange-400 text-sm">{category}</div>
                  </div>
                </div>
                <div class="text-slate-400 flex-grow prose-invert text-[15px]">
                  <Content />
                </div>
              </div>
            );
          })
        }
      </div>
    </section>

    <!-- SEO & MARKET POWER -->
    <section id="seo" class="bg-slate-900 border-y border-slate-800 py-16">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <div class="text-orange-400 text-xs font-bold tracking-[2.5px] mb-3">DATA-BACKED BRAND ASSET</div>
          <h2 class="section-header tracking-[-1.5px]">Own the phrase.<br />Own the search intent.</h2>
        </div>

        <div class="max-w-5xl mx-auto">
          <div class="grid md:grid-cols-12 gap-6 items-center">
            <div class="md:col-span-7 bg-slate-950 border border-slate-700 rounded-3xl p-9">
              <h3 class="font-semibold text-3xl tracking-tight mb-6">Why this domain wins on Google</h3>

              <div class="space-y-6 text-[15px]">
                <div class="flex gap-4">
                  <div class="mt-1 text-orange-400"><i class="fa-solid fa-check-circle fa-lg"></i></div>
                  <div><span class="font-semibold">Exact phrase match</span> — Google loves domains that exactly match popular search queries. This one is gold for the full "stop overthinking and start doing" intent.</div>
                </div>
                <div class="flex gap-4">
                  <div class="mt-1 text-orange-400"><i class="fa-solid fa-check-circle fa-lg"></i></div>
                  <div><span class="font-semibold">High commercial intent</span> — People searching this are not browsing. They are ready to invest in solutions, coaching, tools, or books.</div>
                </div>
                <div class="flex gap-4">
                  <div class="mt-1 text-orange-400"><i class="fa-solid fa-check-circle fa-lg"></i></div>
                  <div><span class="font-semibold">Long-tail domination</span> — Pair the domain with content targeting "how to stop overthinking", "stop overthinking at work", "decision paralysis", etc. You become the authority.</div>
                </div>
              </div>
            </div>

            <div class="md:col-span-5 bg-slate-950 border border-slate-700 rounded-3xl p-9">
              <div class="text-sm uppercase tracking-widest text-orange-400 font-semibold mb-4">THE SELF-IMPROVEMENT ECONOMY</div>
              <div class="space-y-5">
                <div>
                  <div class="flex justify-between items-baseline mb-1.5">
                    <div class="text-4xl font-semibold tabular-nums">{siteConfig.marketSize}</div>
                  </div>
                  <div class="text-sm text-slate-400">Global personal development market size (2025)</div>
                </div>
                <div class="pt-4 border-t border-slate-800">
                  <div class="text-sm leading-snug text-slate-300">Millions of monthly searches around "overthinking", "procrastination", "analysis paralysis", and "how to take action". This domain captures the emotional peak of that journey.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MARKET STATS -->
    <section class="max-w-screen-2xl mx-auto px-8 py-20">
      <div class="text-center mb-10">
        <div class="text-xs font-bold tracking-[2px] text-orange-400 mb-2">BY THE NUMBERS</div>
        <h2 class="text-4xl font-semibold tracking-tight">The metrics behind the movement</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {
          marketStats.map((stat) => (
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 text-center">
              <div class="text-5xl font-extrabold font-display tracking-tight text-white mb-3 stat-number">{stat.data.value}</div>
              <div class="text-sm text-slate-400 mb-2">{stat.data.label}</div>
              <div class="text-xs font-semibold text-orange-400">{stat.data.highlight}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- TESTIMONIALS / SOCIAL PROOF -->
    <section class="max-w-screen-2xl mx-auto px-8 py-20 border-t border-slate-800">
      <div class="text-center mb-10">
        <div class="text-xs font-bold tracking-[2px] text-orange-400 mb-2">WHAT BUYERS &amp; EXPERTS SAY</div>
        <h2 class="text-4xl font-semibold tracking-tight">Real voices from the niche</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8">
          <div class="flex gap-x-1 text-amber-400 mb-4">
            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
          </div>
          <blockquote class="text-lg leading-snug">"If I was launching a new coaching business today, this would be the first domain I'd fight for. It literally sells the transformation before you even explain what you do."</blockquote>
          <div class="mt-8 pt-6 border-t border-slate-700 flex items-center gap-x-3">
            <div class="w-9 h-9 bg-slate-700 rounded-full flex-shrink-0"></div>
            <div>
              <div class="font-medium">Dr. Lena Voss</div>
              <div class="text-xs text-slate-500">Executive Mindset Coach • 12k+ clients</div>
            </div>
          </div>
        </div>

        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8">
          <div class="flex gap-x-1 text-amber-400 mb-4">
            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
          </div>
          <blockquote class="text-lg leading-snug">"We spent 6 months trying to brand our productivity app. This domain would have solved everything on day one. The name is the product promise."</blockquote>
          <div class="mt-8 pt-6 border-t border-slate-700 flex items-center gap-x-3">
            <div class="w-9 h-9 bg-slate-700 rounded-full flex-shrink-0"></div>
            <div>
              <div class="font-medium">Marcus Hale</div>
              <div class="text-xs text-slate-500">Founder, FlowState Labs (acquired)</div>
            </div>
          </div>
        </div>

        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8">
          <div class="flex gap-x-1 text-amber-400 mb-4">
            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
          </div>
          <blockquote class="text-lg leading-snug">"As someone who buys and builds in the self-help space, this is one of the cleanest, most powerful phrase domains I've seen in years. It has real movement energy."</blockquote>
          <div class="mt-8 pt-6 border-t border-slate-700 flex items-center gap-x-3">
            <div class="w-9 h-9 bg-slate-700 rounded-full flex-shrink-0"></div>
            <div>
              <div class="font-medium">Priya Chen</div>
              <div class="text-xs text-slate-500">Portfolio Operator • 40+ digital brands</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section class="max-w-screen-2xl mx-auto px-8 py-20 border-t border-slate-800">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <div class="inline-block px-5 py-1.5 rounded-3xl bg-orange-500 text-white text-xs font-extrabold tracking-[1.5px] mb-4">INVESTMENT OPPORTUNITY</div>
          <h2 class="section-header tracking-[-2px]">Own the brand.<br />Own the movement.</h2>
        </div>

        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-10 md:p-14">
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-y-8">
            <div>
              <div class="text-sm uppercase tracking-[3px] text-orange-400 font-bold mb-2">ASKING PRICE</div>
              <div class="flex items-baseline gap-x-2">
                <span class="text-7xl font-extrabold tabular-nums tracking-[-3px]">{siteConfig.valuationPrice}</span>
              </div>
              <div class="text-sm text-slate-400 mt-1">One-time acquisition • Full ownership transfer</div>

              <div class="mt-6 text-sm max-w-xs">
                <div class="flex items-center gap-x-2 text-emerald-400">
                  <i class="fa-solid fa-check"></i>
                  <span class="font-medium">Comparable premium phrase domains in this niche: {formatValuation(siteConfig.valuationMin, siteConfig.valuationMax)}+</span>
                </div>
              </div>
            </div>

            <div class="lg:text-right">
              <AcquisitionCTA label="Start Acquisition Process" variant="accent" icon="fa-arrow-right-long" />
              <div class="mt-4 text-xs text-slate-400">Serious buyers only • Escrow protected</div>
            </div>
          </div>

          <div class="mt-10 pt-8 border-t border-slate-700 grid grid-cols-1 sm:grid-cols-3 gap-y-6 text-sm">
            <div>
              <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-handshake text-orange-400"></i> <span>Transaction</span></div>
              <div class="text-slate-400">Handled via Escrow.com or your preferred platform. Full domain push + DNS control transfer.</div>
            </div>
            <div>
              <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-file-contract text-orange-400"></i> <span>Support Included</span></div>
              <div class="text-slate-400">Guidance on branding strategy, logo concepts, and initial content direction upon request.</div>
            </div>
            <div>
              <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-globe text-orange-400"></i> <span>Why Now?</span></div>
              <div class="text-slate-400">The self-improvement market continues to explode. Secure this foundational asset before a competitor or larger player does.</div>
            </div>
          </div>
        </div>

        <div class="text-center mt-8 text-xs text-slate-400 max-w-md mx-auto">
          Price reflects end-user value, exact-match keyword strength, brand memorability, and comparable sales in the personal development &amp; productivity niche.
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-screen-2xl mx-auto px-8 pb-20">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-center text-4xl font-semibold tracking-tight mb-10">Frequently Asked Questions</h2>

        <div class="space-y-4">
          <details class="group bg-slate-900 border border-slate-700 rounded-3xl px-8 py-1">
            <summary class="font-semibold cursor-pointer py-5 flex justify-between items-center">Is the domain currently available for purchase?</summary>
            <div class="pb-6 text-slate-300">Yes. This is a direct private sale. No auctions or competing bids. Once we agree on terms, we move quickly to escrow and transfer.</div>
          </details>

          <details class="group bg-slate-900 border border-slate-700 rounded-3xl px-8 py-1">
            <summary class="font-semibold cursor-pointer py-5 flex justify-between items-center">Can I make an offer below the asking price?</summary>
            <div class="pb-6 text-slate-300">We are open to serious, well-qualified offers. Please use the inquiry form and include your intended use and budget. All reasonable offers from serious buyers will be considered.</div>
          </details>

          <details class="group bg-slate-900 border border-slate-700 rounded-3xl px-8 py-1">
            <summary class="font-semibold cursor-pointer py-5 flex justify-between items-center">How long is the domain? Is it brandable?</summary>
            <div class="pb-6 text-slate-300">At 29 characters before .com, it's a full phrase domain — intentionally descriptive and powerful. Many of the strongest brands in self-help use memorable phrases. People will remember it because it speaks directly to their struggle and the solution.</div>
          </details>

          <details class="group bg-slate-900 border border-slate-700 rounded-3xl px-8 py-1">
            <summary class="font-semibold cursor-pointer py-5 flex justify-between items-center">What happens after I purchase?</summary>
            <div class="pb-6 text-slate-300">You receive full ownership via standard domain transfer. We can also provide recommended next steps: hosting setup, basic brand guidelines, content strategy ideas, and logo concepts to help you launch fast.</div>
          </details>

          <details class="group bg-slate-900 border border-slate-700 rounded-3xl px-8 py-1">
            <summary class="font-semibold cursor-pointer py-5 flex justify-between items-center">Is there any trademark risk?</summary>
            <div class="pb-6 text-slate-300">The phrase is generic/descriptive in the self-improvement space and widely used in articles, books, and coaching. No active conflicting trademarks were identified for the exact domain string. Standard due diligence is still recommended.</div>
          </details>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <div class="bg-gradient-to-b from-slate-900 to-slate-950 border-t border-slate-800 py-16">
      <div class="max-w-screen-2xl mx-auto px-8 text-center">
        <div class="max-w-lg mx-auto">
          <h3 class="font-display text-5xl tracking-[-2px] font-extrabold mb-4">Ready to turn<br />overthinkers into <span class="text-orange-400">doers</span>?</h3>
          <p class="text-xl text-slate-300 mb-8">This domain is the foundation for something meaningful.</p>

          <AcquisitionCTA label="Begin Acquisition" variant="white" />
        </div>
      </div>
    </div>
  </main>

  <Footer disclaimer={siteConfig.disclaimer} />
</BaseLayout>
